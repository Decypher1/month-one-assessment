# Ignore Terraform state files and backup
*.tfstate
*.tfstate.backup

# Ignore Terraform crash logs
crash.log

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore the local .terraform directory
.terraform/

# Ignore any generated plan files
*.tfplan

# Ignore key pairs or secrets
*.pem

.terraform.lock.hcl
.terraform.tfvars